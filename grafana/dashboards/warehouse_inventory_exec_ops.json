      "targets": [
        {
          "rawSql": "WITH latest AS (SELECT max(snapshot_date) AS d FROM inventory_mart.fact_inventory_snapshot_daily) SELECT ifNull(w.warehouse_name, s.warehouse_id) AS warehouse, p.sku_id, p.sku_name, p.category, p.brand, s.on_hand_qty, s.available_qty, p.reorder_point, p.max_stock, greatest(p.reorder_point - s.available_qty, 0) AS deficit_qty, CASE WHEN s.available_qty <= 0 THEN 'Stockout' WHEN s.available_qty < p.reorder_point THEN 'Low stock' WHEN s.available_qty > p.max_stock THEN 'Overstock' ELSE 'Healthy' END AS stock_status FROM inventory_mart.fact_inventory_snapshot_daily s INNER JOIN inventory_mart.dim_product p ON s.sku_id = p.sku_id LEFT JOIN inventory_mart.dim_warehouse w ON s.warehouse_id = w.warehouse_id WHERE s.snapshot_date = (SELECT d FROM latest) AND ('${warehouse:raw}'='__all' OR s.warehouse_id IN (${warehouse:singlequote})) AND ('${category:raw}'='__all' OR p.category IN (${category:singlequote})) AND ('${brand:raw}'='__all' OR p.brand IN (${brand:singlequote})) AND ('${stock_status:raw}'='__all' OR CASE WHEN s.available_qty <= 0 THEN 'Stockout' WHEN s.available_qty < p.reorder_point THEN 'Low stock' WHEN s.available_qty > p.max_stock THEN 'Overstock' ELSE 'Healthy' END IN (${stock_status:singlequote})) ORDER BY multiIf(stock_status='Stockout', 1, stock_status='Low stock', 2, stock_status='Overstock', 3, 4), deficit_qty DESC, s.available_qty ASC LIMIT 50",
          "refId": "A"
        }
