          "queryType": "table",
          "rawSql": "SELECT s.warehouse_id, s.sku_id, s.category, ifNull(l.onhand_qty, 0) AS onhand_qty, s.reserved_qty, (ifNull(l.onhand_qty, 0) - s.reserved_qty) AS available_qty, s.reorder_point, (s.reorder_point - (ifNull(l.onhand_qty, 0) - s.reserved_qty)) AS deficit_qty, formatDateTime(ifNull(l.last_movement_time, s.last_movement_time), '%F %T') AS last_movement_at FROM demo_inventory_snapshot s LEFT JOIN (SELECT warehouse_id, sku_id, sum(qty_change) AS onhand_qty, max(event_time) AS last_movement_time FROM raw_inventory_transactions WHERE warehouse_id IN (${warehouse:singlequote}) GROUP BY warehouse_id, sku_id) l ON s.warehouse_id = l.warehouse_id AND s.sku_id = l.sku_id WHERE s.warehouse_id IN (${warehouse:singlequote}) AND (ifNull(l.onhand_qty, 0) - s.reserved_qty) <= s.reorder_point ORDER BY deficit_qty DESC LIMIT 20",
          "refId": "A"
        }
      ],
