      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-inventory"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH latest_snapshot AS (\n  SELECT max(snapshot_date) AS snapshot_date\n  FROM inventory_mart.fact_inventory_snapshot_daily\n)\n\n            SELECT\n              coalesce(w.warehouse_name, s.warehouse_id) AS warehouse,\n              round(sum(s.inventory_value), 2) AS inventory_value\n            FROM inventory_mart.fact_inventory_snapshot_daily s\n            LEFT JOIN inventory_mart.dim_warehouse w ON w.warehouse_id = s.warehouse_id\n            WHERE s.snapshot_date = (SELECT snapshot_date FROM latest_snapshot)\n            GROUP BY warehouse\n            ORDER BY inventory_value DESC",
          "refId": "A"
        }
      ],
