          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT\n  event_date AS time,\n  sum(qty_in) AS inbound_qty,\n  sum(qty_out) AS outbound_qty\nFROM inventory_mart.fact_inventory_movement\nWHERE event_date >= today() - 90\nGROUP BY event_date\nORDER BY event_date",
          "refId": "A"
