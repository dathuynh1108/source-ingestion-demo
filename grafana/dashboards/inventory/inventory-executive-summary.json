    {
      "id": 11,
      "title": "Top Low-stock Items",
      "type": "table",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-inventory"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-inventory"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH latest_snapshot AS (\n  SELECT max(snapshot_date) AS snapshot_date\n  FROM inventory_mart.fact_inventory_snapshot_daily\n)\n\n            SELECT\n              coalesce(w.warehouse_name, s.warehouse_id) AS warehouse,\n              s.sku_id AS sku_id,\n              coalesce(p.sku_name, s.sku_id) AS sku_name,\n              coalesce(p.category, 'Unknown') AS category,\n              s.available_qty AS available_qty,\n              p.reorder_point AS reorder_point,\n              greatest(p.reorder_point - s.available_qty, 0) AS gap_qty,\n              round(s.inventory_value, 2) AS inventory_value\n            FROM inventory_mart.fact_inventory_snapshot_daily s\n            LEFT JOIN inventory_mart.dim_product p ON p.sku_id = s.sku_id\n            LEFT JOIN inventory_mart.dim_warehouse w ON w.warehouse_id = s.warehouse_id\n            WHERE\n              s.snapshot_date = (SELECT snapshot_date FROM latest_snapshot)\n              AND p.reorder_point > 0\n              AND s.available_qty < p.reorder_point\n            ORDER BY gap_qty DESC, inventory_value DESC\n            LIMIT 10",
          "refId": "A"
        }
      ],
      "transparent": false,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      }
    },
    {
      "id": 12,
      "title": "Top Overstock Items",
      "type": "table",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-inventory"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-inventory"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH latest_snapshot AS (\n  SELECT max(snapshot_date) AS snapshot_date\n  FROM inventory_mart.fact_inventory_snapshot_daily\n)\n\n            SELECT\n              coalesce(w.warehouse_name, s.warehouse_id) AS warehouse,\n              s.sku_id AS sku_id,\n              coalesce(p.sku_name, s.sku_id) AS sku_name,\n              coalesce(p.category, 'Unknown') AS category,\n              s.available_qty AS available_qty,\n              p.max_stock AS max_stock,\n              greatest(s.available_qty - p.max_stock, 0) AS excess_qty,\n              round(s.inventory_value, 2) AS inventory_value\n            FROM inventory_mart.fact_inventory_snapshot_daily s\n            LEFT JOIN inventory_mart.dim_product p ON p.sku_id = s.sku_id\n            LEFT JOIN inventory_mart.dim_warehouse w ON w.warehouse_id = s.warehouse_id\n            WHERE\n              s.snapshot_date = (SELECT snapshot_date FROM latest_snapshot)\n              AND p.max_stock > 0\n              AND s.available_qty > p.max_stock\n            ORDER BY excess_qty DESC, inventory_value DESC\n            LIMIT 10",
          "refId": "A"
        }
      ],
      "transparent": false,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
