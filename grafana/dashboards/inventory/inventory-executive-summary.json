    {
      "id": 9,
      "title": "Inventory Value by Warehouse",
      "type": "barchart",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-inventory"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
