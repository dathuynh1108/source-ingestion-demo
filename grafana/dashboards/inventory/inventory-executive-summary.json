    {
      "id": 8,
      "title": "Inbound vs Outbound Trend (90 days)",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-inventory"
      },
      "gridPos": {
        "h": 8,
