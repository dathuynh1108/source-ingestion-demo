      "targets": [
        {
          "rawSql": "WITH latest AS (SELECT max(snapshot_date) AS d FROM inventory_mart.fact_inventory_snapshot_daily), last_move AS (SELECT warehouse_id, sku_id, max(event_date) AS last_event_date FROM inventory_mart.fact_inventory_movement GROUP BY warehouse_id, sku_id) SELECT aging_bucket, round(sum(inventory_value),2) AS aging_value FROM (SELECT s.warehouse_id, s.sku_id, s.inventory_value, dateDiff('day', ifNull(l.last_event_date, s.snapshot_date), (SELECT d FROM latest)) AS days_no_movement, CASE WHEN dateDiff('day', ifNull(l.last_event_date, s.snapshot_date), (SELECT d FROM latest)) <= 30 THEN '0-30' WHEN dateDiff('day', ifNull(l.last_event_date, s.snapshot_date), (SELECT d FROM latest)) <= 60 THEN '31-60' WHEN dateDiff('day', ifNull(l.last_event_date, s.snapshot_date), (SELECT d FROM latest)) <= 90 THEN '61-90' ELSE '90+' END AS aging_bucket FROM inventory_mart.fact_inventory_snapshot_daily s LEFT JOIN last_move l ON s.warehouse_id = l.warehouse_id AND s.sku_id = l.sku_id LEFT JOIN inventory_mart.dim_product p ON s.sku_id = p.sku_id WHERE s.snapshot_date = (SELECT d FROM latest) AND ('${warehouse:raw}'='__all' OR s.warehouse_id IN (${warehouse:singlequote})) AND ('${category:raw}'='__all' OR p.category IN (${category:singlequote})) AND ('${brand:raw}'='__all' OR p.brand IN (${brand:singlequote}))) t GROUP BY aging_bucket ORDER BY aging_bucket",
