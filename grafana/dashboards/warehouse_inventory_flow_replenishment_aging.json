      "pluginVersion": "11.2.0",
      "targets": [
        {
          "rawSql": "WITH latest AS (SELECT max(snapshot_date) AS d FROM inventory_mart.fact_inventory_snapshot_daily), demand AS (SELECT sku_id, avg(qty) AS avg_daily_demand FROM inventory_mart.fact_sales_order_lines WHERE created_date >= addDays(today(), -30) GROUP BY sku_id), open_po AS (SELECT sku_id, sum(qty_open) AS open_po_qty FROM inventory_mart.fact_purchase_order_lines GROUP BY sku_id) SELECT p.sku_id, p.sku_name, p.reorder_point, p.max_stock, sum(s.available_qty) AS current_available, ifNull(d.avg_daily_demand,0) AS avg_daily_demand, ifNull(o.open_po_qty,0) AS open_po_qty, greatest(p.max_stock - sum(s.available_qty) - ifNull(o.open_po_qty,0), 0) AS recommended_reorder_qty FROM inventory_mart.fact_inventory_snapshot_daily s INNER JOIN inventory_mart.dim_product p ON s.sku_id = p.sku_id LEFT JOIN demand d ON p.sku_id = d.sku_id LEFT JOIN open_po o ON p.sku_id = o.sku_id WHERE s.snapshot_date = (SELECT d FROM latest) AND ('${warehouse:raw}'='__all' OR s.warehouse_id IN (${warehouse:singlequote})) AND ('${category:raw}'='__all' OR p.category IN (${category:singlequote})) AND ('${brand:raw}'='__all' OR p.brand IN (${brand:singlequote})) GROUP BY p.sku_id, p.sku_name, p.reorder_point, p.max_stock, d.avg_daily_demand, o.open_po_qty HAVING current_available < p.reorder_point ORDER BY recommended_reorder_qty DESC LIMIT 25",
          "refId": "A"
        }
      ],
      "title": "Replenishment Recommendation",
      "type": "table"
