      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-inventory"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH latest_snapshot AS (\n  SELECT max(snapshot_date) AS snapshot_date\n  FROM inventory_mart.fact_inventory_snapshot_daily\n),\ncurrent_stock AS (\n  SELECT\n    s.sku_id AS sku_id,\n    sum(s.available_qty) AS available_qty\n  FROM inventory_mart.fact_inventory_snapshot_daily s\n  LEFT JOIN inventory_mart.dim_warehouse w ON w.warehouse_id = s.warehouse_id\n  LEFT JOIN inventory_mart.dim_product p ON p.sku_id = s.sku_id\n  WHERE s.snapshot_date = (SELECT snapshot_date FROM latest_snapshot)\n    AND ('${warehouse:raw}'='__all' OR s.warehouse_id IN (${warehouse:singlequote}))\n    AND ('${region:raw}'='__all' OR w.region IN (${region:singlequote}))\n    AND ('${category:raw}'='__all' OR p.category IN (${category:singlequote}))\n    AND ('${brand:raw}'='__all' OR p.brand IN (${brand:singlequote}))\n    AND ('${sku:raw}'='__all' OR s.sku_id IN (${sku:singlequote}))\n  GROUP BY s.sku_id\n),\ndaily_demand AS (\n  SELECT\n    s.sku_id AS sku_id,\n    round(sum(s.qty) / 30, 2) AS avg_daily_demand\n  FROM inventory_mart.fact_sales_order_lines s\n  LEFT JOIN inventory_mart.dim_product p ON p.sku_id = s.sku_id\n  WHERE s.created_date >= today() - 30\n    AND ('${category:raw}'='__all' OR p.category IN (${category:singlequote}))\n    AND ('${brand:raw}'='__all' OR p.brand IN (${brand:singlequote}))\n    AND ('${sku:raw}'='__all' OR s.sku_id IN (${sku:singlequote}))\n  GROUP BY s.sku_id\n)\nSELECT\n  cs.sku_id AS sku_id,\n  coalesce(p.sku_name, cs.sku_id) AS sku_name,\n  coalesce(p.category, 'Unknown') AS category,\n  cs.available_qty,\n  p.reorder_point,\n  p.max_stock,\n  coalesce(dd.avg_daily_demand, 0) AS avg_daily_demand,\n  greatest(p.max_stock - cs.available_qty, 0) AS recommended_reorder_qty,\n  if(p.reorder_point > 0 AND cs.available_qty < p.reorder_point, 'Urgent', 'Watch') AS recommendation_priority,\n  if(coalesce(dd.avg_daily_demand, 0) > 0, round(cs.available_qty / dd.avg_daily_demand, 2), 9999) AS days_of_cover\nFROM current_stock cs\nLEFT JOIN inventory_mart.dim_product p ON p.sku_id = cs.sku_id\nLEFT JOIN daily_demand dd ON dd.sku_id = cs.sku_id\nWHERE (p.reorder_point > 0 OR p.max_stock > 0)\nORDER BY\n  if(p.reorder_point > 0 AND cs.available_qty < p.reorder_point, 1, 0) DESC,\n  recommended_reorder_qty DESC,\n  avg_daily_demand DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Replenishment Recommendation",
      "type": "table"
    },
