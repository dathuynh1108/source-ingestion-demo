          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH latest_snapshot AS (\n  SELECT max(snapshot_date) AS snapshot_date\n  FROM inventory_mart.fact_inventory_snapshot_daily\n)\n\n            SELECT countIf(p.reorder_point > 0 AND s.available_qty < p.reorder_point) AS value\n            FROM inventory_mart.fact_inventory_snapshot_daily s\n            LEFT JOIN inventory_mart.dim_product p ON p.sku_id = s.sku_id\n            LEFT JOIN inventory_mart.dim_warehouse w ON w.warehouse_id = s.warehouse_id\n            WHERE s.snapshot_date = (SELECT snapshot_date FROM latest_snapshot)\n              AND ('${warehouse:raw}'='__all' OR s.warehouse_id IN (${warehouse:singlequote}))\n              AND ('${region:raw}'='__all' OR w.region IN (${region:singlequote}))\n              AND ('${category:raw}'='__all' OR p.category IN (${category:singlequote}))\n              AND ('${brand:raw}'='__all' OR p.brand IN (${brand:singlequote}))\n              AND ('${sku:raw}'='__all' OR s.sku_id IN (${sku:singlequote}))",
          "refId": "A"
        }
      ],
      "title": "Items Below Reorder Point",
      "type": "stat"
