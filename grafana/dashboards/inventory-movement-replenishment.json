          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT toDateTime(created_date) AS time, sum(qty_open) AS open_qty, sum(qty_received) AS received_qty FROM inventory_mart.fact_purchase_order_lines f LEFT JOIN inventory_mart.dim_product p ON f.sku_id = p.sku_id WHERE $__timeFilter(created_date) AND ('${category:raw}'='__all' OR p.category IN (${category:singlequote})) AND ('${brand:raw}'='__all' OR p.brand IN (${brand:singlequote})) AND ('${sku:raw}'='__all' OR f.sku_id IN (${sku:singlequote})) GROUP BY time ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "PO Open vs Received Trend",
      "type": "timeseries"
    }
