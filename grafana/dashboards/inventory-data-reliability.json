          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH latest AS (SELECT max(snapshot_date) AS d FROM inventory_mart.fact_inventory_snapshot_daily) SELECT countIf(s.available_qty < 0) AS negative_stock_rows FROM inventory_mart.fact_inventory_snapshot_daily s LEFT JOIN inventory_mart.dim_product p ON p.sku_id = s.sku_id LEFT JOIN inventory_mart.dim_warehouse w ON w.warehouse_id = s.warehouse_id WHERE s.snapshot_date = (SELECT d FROM latest) AND ('${warehouse:raw}'='__all' OR s.warehouse_id IN (${warehouse:singlequote})) AND ('${region:raw}'='__all' OR w.region IN (${region:singlequote})) AND ('${category:raw}'='__all' OR p.category IN (${category:singlequote})) AND ('${brand:raw}'='__all' OR p.brand IN (${brand:singlequote})) AND ('${sku:raw}'='__all' OR s.sku_id IN (${sku:singlequote}))",
          "refId": "A"
        }
      ],
      "title": "Negative Stock Rows (Latest)",
      "type": "stat"
