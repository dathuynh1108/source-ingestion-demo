MSSQL_SA_PASSWORD=YourStrong!Passw0rd
MSSQL_USER=sa
MSSQL_DATABASE=inventory_demo
SEED_ROWS=180000
SEED_DAYS_BACK=45
LIVE_BATCH_ROWS=250
LIVE_BATCH_INTERVAL_SECONDS=15
LOGSTASH_VERSION=8.19.12
MSSQL_JDBC_VERSION=13.2.1.jre11
LOGSTASH_POLL_INTERVAL=10s
KAFKA_BOOTSTRAP_SERVERS=kafka_broker:9092
KAFKA_TOPIC=inventory_topic

# Grafana dashboard
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

CHATSERVER_ALLOW_ORIGINS=http://localhost:3000
# Azure OpenAI
CHATSERVER_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
CHATSERVER_AZURE_OPENAI_API_KEY=
CHATSERVER_AZURE_OPENAI_API_VERSION=2024-10-21
CHATSERVER_AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.2
CHATSERVER_AZURE_OPENAI_MAX_RETRIES=2

# OpenAI-compatible fallback
CHATSERVER_OPENAI_API_KEY=
CHATSERVER_OPENAI_BASE_URL=
CHATSERVER_OPENAI_MODEL=gpt-5.2
CHATSERVER_OPENAI_TIMEOUT_SECONDS=60
NEXT_PUBLIC_CHATSERVER_URL=http://localhost:8001
NEXT_PUBLIC_CHATSERVER_SOCKET_PATH=/socket.io
NEXT_PUBLIC_CHAT_NAMESPACE=warehouse
