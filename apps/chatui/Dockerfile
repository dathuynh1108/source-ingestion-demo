FROM node:22-alpine AS deps

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

FROM node:22-alpine AS builder

WORKDIR /app

ARG NEXT_PUBLIC_CHATSERVER_URL=http://localhost:8001
ARG NEXT_PUBLIC_CHATSERVER_SOCKET_PATH=/socket.io
ARG NEXT_PUBLIC_CHAT_NAMESPACE=warehouse

ENV NEXT_PUBLIC_CHATSERVER_URL=${NEXT_PUBLIC_CHATSERVER_URL}
ENV NEXT_PUBLIC_CHATSERVER_SOCKET_PATH=${NEXT_PUBLIC_CHATSERVER_SOCKET_PATH}
ENV NEXT_PUBLIC_CHAT_NAMESPACE=${NEXT_PUBLIC_CHAT_NAMESPACE}

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN npm run build

FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000

ARG NEXT_PUBLIC_CHATSERVER_URL=http://localhost:8001
ARG NEXT_PUBLIC_CHATSERVER_SOCKET_PATH=/socket.io
ARG NEXT_PUBLIC_CHAT_NAMESPACE=warehouse

ENV NEXT_PUBLIC_CHATSERVER_URL=${NEXT_PUBLIC_CHATSERVER_URL}
ENV NEXT_PUBLIC_CHATSERVER_SOCKET_PATH=${NEXT_PUBLIC_CHATSERVER_SOCKET_PATH}
ENV NEXT_PUBLIC_CHAT_NAMESPACE=${NEXT_PUBLIC_CHAT_NAMESPACE}

COPY --from=builder /app ./

EXPOSE 3000

CMD ["npm", "run", "start", "--", "-H", "0.0.0.0", "-p", "3000"]
