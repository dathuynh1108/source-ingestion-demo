# SQL Server
MSSQL_SA_PASSWORD=YourStrong!Passw0rd
MSSQL_DATABASE=inventory_demo
MSSQL_USER=sa

# Source data generation
SEED_ROWS=180000
SEED_DAYS_BACK=45
LIVE_BATCH_ROWS=250
LIVE_BATCH_INTERVAL_SECONDS=15

# Logstash
LOGSTASH_VERSION=8.19.12
MSSQL_JDBC_VERSION=13.2.1.jre11
LOGSTASH_POLL_INTERVAL=10s
KAFKA_BOOTSTRAP_SERVERS=kafka_broker:9092
KAFKA_TOPIC=inventory_topic

# Overlay network when plugging into mem3 stack
MEMBER3_NETWORK_NAME=kafka-clickhouse-setup_data_network
